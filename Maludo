	local function createToolBtn(imgId)
		local btn = Instance.new("ImageButton", btnContainer)
		btn.Size = UDim2.new(0, 28, 0, 28)
		btn.Image = "rbxassetid://" .. imgId
		btn.BackgroundColor3 = Color3.fromRGB(45,45,55)
		btn.AutoButtonColor = true
		addCorner(btn, UDim.new(0,6))
		return btn
	end

	local pencilBtn = createToolBtn("133558250287088")
	local bucketBtn = createToolBtn("14721658067")
	local eyedropperBtn = createToolBtn("126362121736567")
	local gridToggleBtn = createToolBtn("126075372455333")
	local trashBtn = createToolBtn("6741600111")
	local upgradeBtn = createToolBtn("18463215792")
	local arteBtn = Instance.new("TextButton", btnContainer)
	arteBtn.Size = UDim2.new(0, 28, 0, 40)
	arteBtn.Text = "Arte"
	arteBtn.TextSize = 10
	arteBtn.Font = FONT_UI
	arteBtn.BackgroundColor3 = Color3.fromRGB(45,90,160)
	arteBtn.TextColor3 = Color3.new(1,1,1)
	arteBtn.TextWrapped = true
	addCorner(arteBtn, UDim.new(0,6))
	local lockBtn = createToolBtn("18209574760")

	local function clearToolBorders()
		for _, btn in pairs({pencilBtn, bucketBtn, eyedropperBtn}) do
			local stroke = btn:FindFirstChild("ToolBorder")
			if stroke then stroke:Destroy() end
		end
	end

	local function setActiveTool(tool)
		activeTool = tool
		clearToolBorders()
		local targetBtn = nil
		if tool == "pencil" then targetBtn = pencilBtn
		elseif tool == "bucket" then targetBtn = bucketBtn
		elseif tool == "eyedropper" then targetBtn = eyedropperBtn end
		if targetBtn then
			local stroke = Instance.new("UIStroke", targetBtn)
			stroke.Name = "ToolBorder"
			stroke.Thickness = 2
			stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
			if tool == "eyedropper" then
				stroke.Color = Color3.fromRGB(200,200,100)
			else
				stroke.Color = (tool == "pencil") and Color3.new(1,1,1) or Color3.fromHex(currentHex)
			end
		end
		if tool == "eyedropper" then
			showTempMessage("🔍 Clique em um pixel para capturar a cor", 2)
		end
	end

	local function updateBucketBorderColor()
		if activeTool == "bucket" and bucketBtn then
			local stroke = bucketBtn:FindFirstChild("ToolBorder")
			if stroke then stroke.Color = Color3.fromHex(currentHex) end
		end
	end

	pencilBtn.MouseButton1Click:Connect(function() setActiveTool("pencil") end)
	bucketBtn.MouseButton1Click:Connect(function() setActiveTool("bucket") end)
	eyedropperBtn.MouseButton1Click:Connect(function() setActiveTool("eyedropper") end)

	gridToggleBtn.MouseButton1Click:Connect(function()
		showGridLines = not showGridLines
		for _, btn in pairs(pixels) do
			local stroke = btn:FindFirstChild("GridStroke")
			if stroke then stroke.Enabled = showGridLines end
		end
		gridToggleBtn.BackgroundColor3 = showGridLines and Color3.fromRGB(80,45,45) or Color3.fromRGB(45,45,55)
	end)

	trashBtn.MouseButton1Click:Connect(function() resetHUD() end)

	upgradeBtn.MouseButton1Click:Connect(function()
		if not upgradeCanvas then
			showTempMessage("❌ Remote de upgrade não encontrado", 3)
			return
		end
		local success, hasPass = pcall(function()
			return game:GetService("MarketplaceService"):UserOwnsGamePassAsync(player.UserId, GAMEPASS_ID)
		end)
		if success and hasPass then
			upgradeCanvas:FireServer()
			task.spawn(function()
				task.wait(1.5)
				if editorWindow.Visible then buildGrid() end
			end)
		else
			showTempMessage("Você não possui a gamepass para aumentar o quadro!", 10)
		end
	end)

	arteBtn.MouseButton1Click:Connect(function()
		if isSending then return end
		board = getMyBoard()
		if not board then
			arteBtn.Text = "sem\nquadro"
			task.wait(1.5)
			arteBtn.Text = "Arte"
			return
		end
		isSending = true
		arteBtn.Text = "..."
		arteBtn.BackgroundColor3 = Color3.fromRGB(30,60,110)
		progBgEditor.Visible = true
		progBarEditor.Size = UDim2.new(0,0,1,0)

		task.spawn(function()
			local needUpdate = {}
			local total = gridSize * gridSize
			for i = 1, total do
				local boardIdx = hudToBoard(i, gridSize)
				local desiredHex = (hudColors[i] or "#FFFFFF"):gsub("#","")
				local pixelPart = board:FindFirstChild(tostring(boardIdx))
				if pixelPart and pixelPart:IsA("BasePart") then
					local targetR = tonumber(desiredHex:sub(1,2),16)/255
					local targetG = tonumber(desiredHex:sub(3,4),16)/255
					local targetB = tonumber(desiredHex:sub(5,6),16)/255
					local c = pixelPart.Color
					local diff = (c.R - targetR)^2 + (c.G - targetG)^2 + (c.B - targetB)^2
					if diff > 0.001 then
						table.insert(needUpdate, {id = tostring(boardIdx), color = desiredHex})
					end
				else
					table.insert(needUpdate, {id = tostring(boardIdx), color = desiredHex})
				end
			end

			local totalToUpdate = #needUpdate
			if totalToUpdate == 0 then
				progBarEditor.Size = UDim2.new(1, 0, 1, 0)
				task.wait(0.5)
			else
				local packet = {}
				local count = 0
				for idx, data in ipairs(needUpdate) do
					packet[data.id] = data.color
					count = count + 1
					if count >= 128 or idx == totalToUpdate then
						pcall(function() updateBoard:InvokeServer(packet) end)
						packet = {}
						count = 0
						progBarEditor.Size = UDim2.new(idx / totalToUpdate, 0, 1, 0)
						task.wait(0.02)
					end
				end
			end

			task.wait(0.3)
			isSending = false
			arteBtn.Text = "Arte"
			arteBtn.BackgroundColor3 = Color3.fromRGB(45,90,160)
			progBgEditor.Visible = false
		end)
	end)

	local function updateLockUI()
		lockBtn.Image = "rbxassetid://" .. (guiDraggable and "18209574760" or "18209587260")
	end

	lockBtn.MouseButton1Click:Connect(function()
		guiDraggable = not guiDraggable
		editorWindow.Draggable = guiDraggable
		updateLockUI()
	end)
	editorWindow.Draggable = guiDraggable
	updateLockUI()

	local function updateValueStripGradient()
		valueGradient.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromHSV(colorH, 1, 1)),
			ColorSequenceKeypoint.new(1, Color3.new(0,0,0))
		})
	end

	local function updateHueKnob()
		local height = hueStrip.AbsoluteSize.Y
		if height == 0 then return end
		local knobH = hueKnob.AbsoluteSize.Y
		hueKnob.Position = UDim2.new(0, -2, 0, colorH * (height - knobH))
	end

	local function updateValueKnob()
		local height = valueStrip.AbsoluteSize.Y
		if height == 0 then return end
		local knobH = valueKnob.AbsoluteSize.Y
		valueKnob.Position = UDim2.new(0, -2, 0, (1 - colorV) * (height - knobH))
	end

	function updateColorFromHSV()
		currentHex = hsvToHex(colorH, colorS, colorV)
		preview.BackgroundColor3 = Color3.fromHex(currentHex)
		hexLabel.Text = currentHex
		updateValueStripGradient()
		updateHueKnob()
		updateValueKnob()
		if activeTool == "bucket" then updateBucketBorderColor() end
	end

	local function setColorFromHex(hex)
		local r = tonumber(hex:sub(2,3),16)/255
		local g = tonumber(hex:sub(4,5),16)/255
		local b = tonumber(hex:sub(6,7),16)/255
		local h, s, v = Color3.new(r,g,b):ToHSV()
		colorH, colorS, colorV = h, s, v
		updateColorFromHSV()
	end

	local function setHueFromPosition(inputPosition)
		colorS = 1
		local frame = hueStrip
		local absPos = frame.AbsolutePosition
		local size = frame.AbsoluteSize
		local y = math.clamp((inputPosition.Y - absPos.Y) / size.Y, 0, 1)
		colorH = y
		updateColorFromHSV()
	end

	local function setValueFromPosition(inputPosition)
		if valueLocked then return end
		colorS = 1
		local frame = valueStrip
		local absPos = frame.AbsolutePosition
		local size = frame.AbsoluteSize
		local y = math.clamp((inputPosition.Y - absPos.Y) / size.Y, 0, 1)
		colorV = 1 - y
		updateColorFromHSV()
	end

	local hueDragging, valueDragging = false, false

	local function onHueInputBegan(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			setHueFromPosition(input.Position)
			hueDragging = true
		end
	end

	local function onValueInputBegan(input)
		if valueLocked then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			setValueFromPosition(input.Position)
			valueDragging = true
		end
	end

	local function onInputMoved(input)
		if hueDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			setHueFromPosition(input.Position)
		elseif valueDragging and not valueLocked and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			setValueFromPosition(input.Position)
		end
	end

	local function onInputEnded(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			hueDragging = false
			valueDragging = false
			painting = false
		end
	end

	hueStrip.InputBegan:Connect(onHueInputBegan)
	valueStrip.InputBegan:Connect(onValueInputBegan)
	UserInputService.InputChanged:Connect(onInputMoved)
	UserInputService.InputEnded:Connect(onInputEnded)

	valueLockBtn.MouseButton1Click:Connect(function()
		valueLocked = not valueLocked
		valueLockBtn.Text = valueLocked and "🔒" or "🔓"
		valueLockBtn.BackgroundColor3 = valueLocked and Color3.fromRGB(70,40,40) or Color3.fromRGB(45,45,55)
		showTempMessage(valueLocked and "🔒 Tom bloqueado" or "🔓 Tom desbloqueado", 1)
	end)

	hexLabel.FocusLost:Connect(function()
		local h = hexLabel.Text:gsub("#","")
		if #h == 6 and h:match("^%x+$") then
			currentHex = "#"..h:upper()
			preview.BackgroundColor3 = Color3.fromHex(currentHex)
			local r = tonumber(h:sub(1,2),16)/255
			local g = tonumber(h:sub(3,4),16)/255
			local b = tonumber(h:sub(5,6),16)/255
			colorH, colorS, colorV = Color3.new(r,g,b):ToHSV()
			updateColorFromHSV()
		end
	end)

	local function attachPixelEvents()
		for i, btn in pairs(pixels) do
			btn.MouseButton1Down:Connect(function()
				if activeTool == "eyedropper" then
					local pickedHex = hudColors[i] or "#FFFFFF"
					setColorFromHex(pickedHex)
					setActiveTool("pencil")
					showTempMessage("✅ Cor capturada: "..pickedHex, 1.5)
					return
				end
				painting = true
				if activeTool == "bucket" then
					local targetHex = hudColors[i] or "#FFFFFF"
					task.spawn(function() floodFillHUD(i, targetHex, currentHex, gridSize) end)
				elseif activeTool == "pencil" then
					hudColors[i] = currentHex
					btn.BackgroundColor3 = Color3.fromHex(currentHex)
				end
			end)
			btn.MouseEnter:Connect(function()
				if painting and activeTool == "pencil" then
					hudColors[i] = currentHex
					btn.BackgroundColor3 = Color3.fromHex(currentHex)
				end
			end)
		end
	end

	function buildGrid()
		for _, b in pairs(pixels) do if b then b:Destroy() end end
		pixels = {}
		hudColors = {}
		board = getMyBoard()
		if not board then return end
		gridSize = getGridSize(board)
		local innerSize = gridInner.AbsoluteSize.X
		if innerSize == 0 then task.wait(); innerSize = gridInner.AbsoluteSize.X end
		local cellSize = math.floor(innerSize / gridSize)
		gridLayout.CellSize = UDim2.new(0, cellSize, 0, cellSize)
		gridLayout.FillDirectionMaxCells = gridSize
		gridInner.Size = UDim2.new(0, cellSize * gridSize + 2, 0, cellSize * gridSize + 2)
		for i = 1, gridSize * gridSize do
			local boardIdx = hudToBoard(i, gridSize)
			local hex = getPixelHex(board, boardIdx)
			hudColors[i] = hex
			local btn = Instance.new("ImageButton", gridInner)
			btn.BackgroundColor3 = Color3.fromHex(hex)
			btn.BorderSizePixel = 0
			btn.AutoButtonColor = false
			btn.LayoutOrder = i
			local stroke = Instance.new("UIStroke", btn)
			stroke.Name = "GridStroke"
			stroke.Color = Color3.fromRGB(35, 35, 40)
			stroke.Thickness = 1
			stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
			stroke.Enabled = showGridLines
			pixels[i] = btn
		end
		attachPixelEvents()
	end

	editorWindow:GetPropertyChangedSignal("Visible"):Connect(function()
		if editorWindow.Visible then
			buildGrid()
			updateColorFromHSV()
		else
			painting = false
			isSending = false
		end
	end)

	buildGrid()
	updateColorFromHSV()
end
buildEditorGUI(editorContent)

