-- FUNÇÕES AUXILIARES DE UI
-- =====================================================
local function addCorner(parent, radius)
	local c = Instance.new("UICorner", parent)
	c.CornerRadius = radius or UDim.new(0, 10)
	return c
end

local function addStroke(parent, color, thickness)
	local s = Instance.new("UIStroke", parent)
	s.Color = color or STROKE_COLOR
	s.Thickness = thickness or 1
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	return s
end

-- Arrasta a janela a partir de qualquer área vazia (não interativa)
local function makeDraggableFromEmptySpace(window, contentArea)
	window.Active = true
	local dragging, dragStart, startPos

	contentArea.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			-- Permite arrastar apenas se o alvo não for um controle interativo
			local target = input.UserInputType == Enum.UserInputType.MouseButton1 and UserInputService:GetFocusedTextBox() or nil
			local obj = input.UserInputType == Enum.UserInputType.Touch and input.Touch and input.Touch.Position and nil
			-- Abordagem mais confiável: verificamos a classe do objeto que recebeu o input
			local objHit = nil
			pcall(function()
				objHit = UserInputService:GetMouseLocation() and nil  -- não confiável
			end)
			-- Vamos usar o fato de que o InputBegan é disparado no elemento mais específico.
			-- Se o script está aqui, já está no contentArea; mas se o clique foi num botão, o InputBegan do botão será disparado antes e não chegará aqui? 
			-- Na verdade, o InputBegan propaga para os pais, então chegará aqui também.
			-- Precisamos saber se o alvo é um botão. Podemos usar input.UserInputState e o objeto alvo: input.Object? Não disponível em InputBegan.
			-- Alternativa: adicionar um manipulador que inicia o arrasto apenas se nenhum botão capturou o evento.
			-- Vamos definir um atributo nos botões e verificar se o alvo possui esse atributo.
			-- Forma mais simples: definir um valor "AllowDrag" no contentArea e nos botões definir como false.
			-- Infelizmente, InputBegan não dá acesso direto ao alvo.
			-- Vou mudar a estratégia: usar UIS (UserInputService) diretamente e detectar clique sobre a janela, mas só se o objeto sob o mouse não for um botão.
			-- Isso é complexo. Prefiro manter a barra superior como alça principal e também permitir arrasto clicando em qualquer lugar vazio, mas com um pequeno hack:
			-- Vamos colocar um Frame transparente enorme sobre todo o conteúdo (menos os botões) e usar esse Frame como alça.
		end
	end)
end

-- Decidi por uma solução mais limpa: o arrasto ocorre apenas pela barra superior e por uma área de arrasto adicional (todo o fundo da janela).
-- A área de arrasto extra será um Frame transparente cobrindo todo o conteúdo, colocado atrás de todos os elementos.
-- Assim, qualquer clique no "vazio" ativa o arrasto.
local function createRoundedWindow(titleText, w, h, x, y, windowName)
	local window = Instance.new("Frame")
	window.Size = UDim2.new(0, w, 0, h)
	window.Position = UDim2.new(0, x, 0, y)
	window.BackgroundColor3 = PANEL_BG
	window.BackgroundTransparency = WINDOW_TRANSPARENCY
	window.BorderSizePixel = 0
	window.Visible = false
	window.ClipsDescendants = true
	window.Parent = gui
	window.Name = windowName or titleText
	addCorner(window, UDim.new(0, 12))
	addStroke(window, STROKE_COLOR, 2)

	local inner = Instance.new("Frame")
	inner.Size = UDim2.new(1, -2, 1, -2)
	inner.Position = UDim2.new(0, 1, 0, 1)
	inner.BackgroundColor3 = PANEL_BG
	inner.BackgroundTransparency = WINDOW_TRANSPARENCY
	inner.BorderSizePixel = 0
	inner.ClipsDescendants = true
	inner.Parent = window
	addCorner(inner, UDim.new(0, 11))

	local topBar = Instance.new("Frame")
	topBar.Size = UDim2.new(1, 0, 0, 32)
	topBar.BackgroundColor3 = BG_COLOR
	topBar.BackgroundTransparency = WINDOW_TRANSPARENCY
	topBar.BorderSizePixel = 0
	topBar.Parent = inner
	addCorner(topBar, UDim.new(0, 11))

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1, -40, 1, 0)
	title.Position = UDim2.new(0, 12, 0, 0)
	title.BackgroundTransparency = 1
	title.Text = titleText
	title.Font = FONT_UI
	title.TextSize = 16
	title.TextColor3 = TEXT_COLOR
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Parent = topBar

	local closeBtn = Instance.new("TextButton")
	closeBtn.Size = UDim2.new(0, 24, 0, 24)
	closeBtn.Position = UDim2.new(1, -30, 0, 4)
	closeBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 65)
	closeBtn.BackgroundTransparency = WINDOW_TRANSPARENCY
	closeBtn.Text = "×"
	closeBtn.Font = FONT_UI
	closeBtn.TextSize = 18
	closeBtn.TextColor3 = TEXT_COLOR
	closeBtn.AutoButtonColor = true
	closeBtn.Parent = topBar
	addCorner(closeBtn, UDim.new(1, 0))
	addStroke(closeBtn, Color3.fromRGB(80, 80, 90), 1)

	local content = Instance.new("Frame")
	content.Size = UDim2.new(1, 0, 1, -32)
	content.Position = UDim2.new(0, 0, 0, 32)
	content.BackgroundColor3 = PANEL_BG
	content.BackgroundTransparency = WINDOW_TRANSPARENCY
	content.BorderSizePixel = 0
	content.Parent = inner

	-- Frame invisível de arrasto (cobre todo o conteúdo, mas fica atrás dos filhos)
	local dragArea = Instance.new("TextButton")
	dragArea.Size = UDim2.new(1, 0, 1, 0)
	dragArea.BackgroundTransparency = 1
	dragArea.Text = ""
	dragArea.AutoButtonColor = false
	dragArea.ZIndex = 0   -- ficar atrás
	dragArea.Parent = content
	dragArea.Active = false  -- não captura eventos de botão

	-- Arrasto pela barra superior
	window.Active = true
	local dragging, dragStart, startPos

	local function onDragStart(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = window.Position
		end
	end

	local function onDragMove(input)
		if not dragging then return end
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			local delta = input.Position - dragStart
			window.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
		end
	end

	local function onDragEnd(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
			-- Salvar posição
			windowPositions[windowName] = window.Position
		end
	end

	topBar.InputBegan:Connect(onDragStart)
	-- Arrasto pela área vazia (o TextButton transparente)
	dragArea.InputBegan:Connect(onDragStart)
	UserInputService.InputChanged:Connect(onDragMove)
	UserInputService.InputEnded:Connect(onDragEnd)

	closeBtn.MouseButton1Click:Connect(function()
		window.Visible = false
	end)

	-- Ao mostrar a janela, restaurar posição ou centralizar
	local function onVisibilityChanged()
		if window.Visible then
			if windowPositions[windowName] then
				window.Position = windowPositions[windowName]
			else
				-- Centralizar
				local viewportSize = Camera.ViewportSize
				window.Position = UDim2.new(0, (viewportSize.X - w)/2, 0, (viewportSize.Y - h)/2)
			end
		end
	end

	window:GetPropertyChangedSignal("Visible"):Connect(onVisibilityChanged)

	return window, content
end

