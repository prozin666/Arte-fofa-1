	progBarEditor.Size = UDim2.new(0,0,1,0)
	progBarEditor.BackgroundColor3 = Color3.fromRGB(60,180,100)
	addCorner(progBarEditor, UDim.new(0,3))

	local tempMsg = Instance.new("TextLabel", content)
	tempMsg.Size = UDim2.new(0, GS, 0, 30)
	tempMsg.Position = UDim2.new(0, SIDEBAR + MARGIN, 0, GS + 16)
	tempMsg.BackgroundColor3 = Color3.fromRGB(0,0,0,0.8)
	tempMsg.TextColor3 = Color3.fromRGB(255,200,100)
	tempMsg.TextSize = 11
	tempMsg.Font = FONT_UI
	tempMsg.Text = ""
