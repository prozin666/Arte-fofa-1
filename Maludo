	local function getPixelHex(container, idx)
		local part = container:FindFirstChild(tostring(idx))
		if part and part:IsA("BasePart") then
			local c = part.Color
			return string.format("#%02X%02X%02X", math.floor(c.R*255+.5), math.floor(c.G*255+.5), math.floor(c.B*255+.5))
		end
		return "#FFFFFF"
	end

	local function hsvToRgb(h, s, v)
		if s == 0 then return v, v, v end
		local i = math.floor(h*6) % 6
		local f = h*6 - math.floor(h*6)
		local p, q, t = v*(1-s), v*(1-f*s), v*(1-(1-f)*s)
		if i==0 then return v,t,p elseif i==1 then return q,v,p
		elseif i==2 then return p,v,t elseif i==3 then return p,q,v
		elseif i==4 then return t,p,v else return v,p,q end
	end

	local function hsvToHex(h, s, v)
		local r,g,b = hsvToRgb(h,s,v)
		return string.format("#%02X%02X%02X", math.floor(r*255+.5), math.floor(g*255+.5), math.floor(b*255+.5))
	end

	local function hudToBoard(i, g)
		local zero = i - 1
		local y = math.floor(zero / g)
		local x = zero % g
		local flippedX = (g - 1) - x
		return y * g + flippedX + 1
	end

	local function floodFillHUD(startI, targetHex, newHex, g)
		if targetHex == newHex then return end
		local total = g*g
		local queue, visited = {startI}, {[startI]=true}
		while #queue > 0 do
			local p = table.remove(queue)
			hudColors[p] = newHex
			if pixels[p] then pixels[p].BackgroundColor3 = Color3.fromHex(newHex) end
			local x, y = (p-1)%g, math.floor((p-1)/g)
			for _, nb in ipairs({p-g, p+g, p-1, p+1}) do
				if nb>=1 and nb<=total and not visited[nb] then
					local nx, ny = (nb-1)%g, math.floor((nb-1)/g)
					if (nx==x and math.abs(ny-y)==1) or (ny==y and math.abs(nx-x)==1) then
						if hudColors[nb] == targetHex then
							visited[nb]=true
							table.insert(queue, nb)
						end
					end
				end
			end
		end
	end

